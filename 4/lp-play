<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Personal Vinyl Player</title>
    <link href="https://fonts.googleapis.com/css2?family=Pretendard:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #000; --accent: #ff4d4d; }
        * { box-sizing: border-box; touch-action: none; user-select: none; }
        
        body {
            margin: 0; height: 100vh; display: flex; justify-content: center; align-items: center;
            background: var(--bg); font-family: 'Pretendard', sans-serif; overflow: hidden; color: white;
        }

        /* 메인 재생 영역 */
        .vinyl-deck {
            position: relative; display: flex; align-items: center; justify-content: center;
            width: 650px; height: 400px;
        }
        .jacket {
            position: relative; width: 320px; height: 320px; background: #222 center/cover;
            border-radius: 4px; z-index: 10; box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8);
            transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1); cursor: pointer;
        }
        .vinyl {
            position: absolute; width: 310px; height: 310px;
            background: radial-gradient(circle, #222 25%, #050505 100%);
            border-radius: 50%; z-index: 5; left: 50%; transform: translateX(-50%);
            display: flex; justify-content: center; align-items: center;
            transition: left 0.7s cubic-bezier(0.33, 1, 0.68, 1); cursor: pointer;
        }
        .label { width: 110px; height: 110px; border-radius: 50%; border: 3px solid #000; background: center/cover; }
        
        /* 재생 상태 */
        .vinyl-deck.active .jacket { transform: translateX(-80px) rotateY(-10deg); }
        .vinyl-deck.active .vinyl { left: calc(50% + 120px); animation: spin 6s linear infinite 0.7s; }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

        /* 목록 아이콘 */
        .trigger {
            position: absolute; bottom: 40px; left: 40px; width: 50px; height: 50px;
            background: rgba(255,255,255,0.1); border-radius: 50%;
            display: flex; justify-content: center; align-items: center; cursor: pointer; z-index: 100;
        }

        /* 목록 모달 */
        .modal {
            position: absolute; inset: 0; background: rgba(0,0,0,0.96); z-index: 1000;
            display: none; flex-direction: column; align-items: center; justify-content: center;
            backdrop-filter: blur(20px);
        }

        .upload-row { width: 100%; max-width: 400px; display: flex; gap: 10px; margin-bottom: 30px; z-index: 1001; }
        .upload-row input { flex: 1; background: #1a1a1a; border: 1px solid #333; padding: 12px; color: #fff; border-radius: 8px; outline: none; }
        .upload-row button { background: var(--accent); border: none; padding: 0 20px; color: #fff; border-radius: 8px; cursor: pointer; font-weight: 600; }

        .scroll-container {
            width: 100%; height: 400px; display: flex; align-items: center;
            overflow-x: auto; scrollbar-width: none; padding: 0 35%;
        }
        .scroll-container::-webkit-scrollbar { display: none; }

        .card {
            position: relative; flex: 0 0 260px; height: 260px; margin: 0 30px;
            background-size: cover; background-position: center; border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5); cursor: grab;
            transition: transform 0.2s ease, opacity 0.2s; transform: rotateY(-15deg);
            z-index: 1;
        }
        .card:hover { transform: rotateY(0deg) scale(1.1) translateZ(50px); z-index: 100; }
        .card.fly-away { transform: translateY(-300%) scale(0.1) rotate(45deg) !important; opacity: 0 !important; transition: all 0.7s cubic-bezier(0.5, 0, 1, 1) !important; }

        #yt-api { position: absolute; width: 0; height: 0; visibility: hidden; }
        .empty-hint { color: #444; font-size: 14px; text-align: center; margin-top: 50px; }
    </style>
</head>
<body>

    <div class="vinyl-deck" id="mainDeck">
        <div class="jacket" id="mainJacket" onclick="playCurrent()"></div>
        <div class="vinyl" id="mainVinyl" onclick="pauseCurrent()">
            <div class="label" id="mainLabel"></div>
        </div>
    </div>

    <div class="trigger" onclick="openModal()">
        <svg viewBox="0 0 24 24" width="22" fill="white"><path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/></svg>
    </div>

    <div class="modal" id="modal">
        <div class="upload-row">
            <input type="text" id="ytUrl" placeholder="YouTube URL 붙여넣기">
            <button onclick="addList()">저장</button>
        </div>
        <div class="scroll-container" id="slider"></div>
        <p style="cursor:pointer; font-size:14px; margin-top:15px; color:#555;" onclick="closeModal()">닫기</p>
    </div>

    <div id="yt-api"></div>

    <script>
        const deck = document.getElementById('mainDeck');
        const modal = document.getElementById('modal');
        const slider = document.getElementById('slider');
        
        // [변경] 초기 샘플 데이터를 삭제하고 빈 배열로 시작하거나 저장된 데이터를 불러옵니다.
        let playlist = JSON.parse(localStorage.getItem('myVinylList')) || [];
        let currentId = playlist[0] ? playlist[0].id : "";

        function openModal() { modal.style.display = 'flex'; render(); }
        function closeModal() { modal.style.display = 'none'; }

        function saveToStorage() {
            localStorage.setItem('myVinylList', JSON.stringify(playlist));
        }

        function render() {
            slider.innerHTML = "";
            if (playlist.length === 0) {
                slider.innerHTML = '<div class="empty-hint">저장된 음악이 없습니다. 링크를 추가해주세요.</div>';
                return;
            }
            playlist.forEach((item, i) => {
                const card = document.createElement('div');
                card.className = 'card';
                card.style.backgroundImage = `url(https://img.youtube.com/vi/${item.id}/mqdefault.jpg)`;
                attachGesture(card, i);
                slider.appendChild(card);
            });
        }

        function attachGesture(el, index) {
            let startY = 0, moveY = 0, isDragging = false;
            const onStart = (e) => {
                isDragging = true;
                startY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
                el.style.transition = 'none';
            };
            const onMove = (e) => {
                if (!isDragging) return;
                const currentY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
                moveY = currentY - startY;
                if (moveY < 0) {
                    el.style.transform = `translateY(${moveY}px) scale(${1 - Math.abs(moveY)/1000})`;
                    el.style.opacity = 1 - Math.abs(moveY)/500;
                }
            };
            const onEnd = () => {
                if (!isDragging) return;
                isDragging = false;
                if (moveY < -100) {
                    el.classList.add('fly-away');
                    setTimeout(() => {
                        playlist.splice(index, 1);
                        saveToStorage();
                        render();
                    }, 600);
                } else if (Math.abs(moveY) < 5) {
                    selectMusic(playlist[index].id);
                } else {
                    el.style.transition = 'all 0.4s ease';
                    el.style.transform = `rotateY(-15deg)`;
                    el.style.opacity = '1';
                }
                moveY = 0;
            };
            el.addEventListener('mousedown', onStart);
            window.addEventListener('mousemove', onMove);
            window.addEventListener('mouseup', onEnd);
            el.addEventListener('touchstart', onStart, {passive: false});
            window.addEventListener('touchmove', onMove, {passive: false});
            window.addEventListener('touchend', onEnd);
        }

        function playCurrent() {
            if (!deck.classList.contains('active') && currentId) {
                deck.classList.add('active');
                document.getElementById('yt-api').innerHTML = `<iframe src="https://www.youtube.com/embed/${currentId}?autoplay=1" allow="autoplay"></iframe>`;
            }
        }

        function pauseCurrent() {
            if (deck.classList.contains('active')) {
                deck.classList.remove('active');
                document.getElementById('yt-api').innerHTML = ""; 
            }
        }

        function selectMusic(id) {
            currentId = id;
            const img = `https://img.youtube.com/vi/${id}/maxresdefault.jpg`;
            document.getElementById('mainJacket').style.backgroundImage = `url(${img})`;
            document.getElementById('mainLabel').style.backgroundImage = `url(${img})`;
            pauseCurrent();
            closeModal();
        }

        function addList() {
            const val = document.getElementById('ytUrl').value;
            const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
            const id = (val.match(regExp)) ? val.match(regExp)[2] : null;
            if (id) {
                playlist.unshift({id});
                saveToStorage();
                render();
                document.getElementById('ytUrl').value = "";
            }
        }

        slider.onwheel = (e) => { slider.scrollLeft += e.deltaY; };
        
        window.onload = () => {
            if (playlist.length > 0) selectMusic(playlist[0].id);
        };
    </script>
</body>
</html>
